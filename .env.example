# Optional: set this to the final custom production domain.
# Vercel's generated deployment URL is used automatically when this is omitted.
NEXT_PUBLIC_SITE_URL=https://www.divineschool.edu.gh

# Required for contact/admissions delivery and newsletter contacts.
RESEND_API_KEY=
FORMS_FROM_EMAIL="Divine International School <website@divineschool.edu.gh>"
FORMS_TO_EMAIL=info@divineschool.edu.gh

# Optional: add newsletter contacts to a specific Resend segment.
RESEND_NEWSLETTER_SEGMENT_ID=

# Add only verified official school social accounts.
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_TIKTOK_URL=
